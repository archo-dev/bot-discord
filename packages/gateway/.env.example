# Copier vers .env (chargé par systemd EnvironmentFile ou `tsx --env-file=.env` en dev)

# Token du bot — le même que le secret DISCORD_TOKEN du Worker
DISCORD_TOKEN=

# Origine du Worker en production
WORKER_ORIGIN=https://botdiscord.archodev.workers.dev

# Même valeur que le secret INTERNAL_API_TOKEN du Worker
INTERNAL_API_TOKEN=
INTERNAL_API_KEY_ID=gw-current

# Aléatoire (openssl rand -hex 32) — à uploader aussi côté Worker (secret GATEWAY_HTTP_TOKEN)
GATEWAY_HTTP_TOKEN=
GATEWAY_HTTP_KEY_ID=worker-current
# Rotation transitoire uniquement : ancienne valeur et son identifiant.
GATEWAY_HTTP_TOKEN_PREVIOUS=
GATEWAY_HTTP_PREVIOUS_KEY_ID=worker-previous
# dual pendant le rolling deploy, signed après validation des deux côtés.
GATEWAY_INTERNAL_AUTH_MODE=dual

# Port HTTP local (exposé uniquement via le tunnel cloudflared)
GATEWAY_PORT=8788
