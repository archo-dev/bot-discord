# Runtime staging isole. Copy to .env.staging on the VPS and chmod 600.
# The three secret values stay outside the repository and must never be copied
# from production.
DISCORD_TOKEN=
INTERNAL_API_TOKEN=
GATEWAY_HTTP_TOKEN=

# Public safety guards: the runtime refuses a token from another application,
# and all outbound writes target the staging Worker only.
DISCORD_CLIENT_ID=1529353871619522600
WORKER_ORIGIN=https://botdiscord-staging.archodev.workers.dev
GATEWAY_PORT=8789
PRESENCE_ENABLED=false
GATEWAY_OUTBOX_PATH=/home/ubuntu/.botdiscord-staging/outbox.db
GATEWAY_BUILD_VERSION=staging
