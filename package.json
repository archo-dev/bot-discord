{
  "name": "archodev",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "dev": "pnpm --filter @bot/worker dev",
    "dev:panel": "pnpm --filter @bot/panel dev",
    "dev:gateway": "pnpm --filter @bot/gateway dev",
    "build": "pnpm --filter @bot/panel build",
    "build:production": "pnpm --filter @bot/panel build",
    "build:staging": "pnpm --filter @bot/panel run build:staging",
    "deploy:production": "node scripts/verify-worker-flags.mjs production && pnpm --filter @bot/panel build && pnpm --filter @bot/worker run deploy",
    "deploy:staging": "node scripts/verify-worker-flags.mjs staging && pnpm --filter @bot/panel run build:staging && pnpm --filter @bot/worker run deploy:staging",
    "deploy": "pnpm run deploy:production",
    "check": "pnpm -r check",
    "test": "pnpm -r test",
    "register:dev": "tsx scripts/register-commands.ts dev",
    "register:global": "tsx scripts/register-commands.ts global",
    "commands:validate": "tsx scripts/register-commands.ts validate",
    "commands:list": "tsx scripts/register-commands.ts list",
    "commands:diff": "tsx scripts/register-commands.ts diff",
    "commands:sync:global": "tsx scripts/register-commands.ts sync-global",
    "commands:sync:guild": "tsx scripts/register-commands.ts sync-guild",
    "commands:cleanup:guild": "tsx scripts/register-commands.ts cleanup-guild",
    "interactions:configure:staging": "tsx scripts/configure-staging-interactions.ts",
    "migrate:local": "pnpm --filter @bot/worker migrate:local",
    "migrate:remote": "pnpm --filter @bot/worker migrate:remote"
  },
  "devDependencies": {
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
